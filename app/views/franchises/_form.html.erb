<%= form_with model: franchise do |f| %>
  <% if franchise.errors.any? %>
    <div>
      <h2><%= pluralize(franchise.errors.count, "erro") %> impediram o salvamento:</h2>
      <ul>
        <% franchise.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Nome da Franquia" %><br>
    <%= f.text_field :name %>
  </div>

  <br>

  <div>
    <%= f.submit "Criar Franquia" %>
  </div>
<% end %>